# === APP KONFIGURATION ===
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Kleinkunst Dashboard

# === BACKEND PROVIDER ===
# Erlaubt: google-cloud, supabase, self-hosted-postgres, neon, appwrite
# Default im Code: google-cloud
BACKEND_PROVIDER=google-cloud
SUPABASE_MIGRATION_EARLIEST_DATE=2026-07-24

# === GOOGLE CLOUD DEFAULT-PFAD ===
GOOGLE_CLOUD_PROJECT_ID=
GOOGLE_CLOUD_REGION=europe-west3
CLOUD_RUN_SERVICE=kleinkunst-dashboard
ARTIFACT_REGISTRY_REPOSITORY=kleinkunst
GOOGLE_CLOUD_SQL_INSTANCE=
GOOGLE_CLOUD_SQL_INSTANCE_NAME=kleinkunst-postgres
GOOGLE_CLOUD_SQL_DATABASE=kleinkunst
GOOGLE_CLOUD_SQL_USER=kleinkunst_app
GOOGLE_CLOUD_SQL_CONNECTION_MODE=unix-socket
GOOGLE_CLOUD_RUN_SERVICE_ACCOUNT=kleinkunst-run
GOOGLE_CLOUD_MIGRATION_BUCKET=
GOOGLE_CLOUD_STORAGE_BUCKET=
GOOGLE_CLOUD_TASKS_QUEUE=kleinkunst-jobs
GOOGLE_CLOUD_PUBSUB_TOPIC=kleinkunst-events

# Identity Platform / Firebase Auth kompatible Web-Konfiguration
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=

# Direkte Postgres-Verbindung fuer Server-Code, Migrationen und Tests.
# In Cloud Run die Cloud-SQL-Instanz mit dem Service verbinden; lokal kann
# Cloud SQL Auth Proxy oder ein lokaler Postgres verwendet werden.
DATABASE_URL=postgresql://kleinkunst_app:password@localhost:5432/kleinkunst

# === SUPABASE: VORBEREITET, ABER NICHT VOR 2026-07-24 AKTIVIEREN ===
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# === SELF-HOSTED / ALTERNATIVEN ===
REDIS_URL=redis://localhost:6379
S3_ENDPOINT=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET=

# === SMTP / E-MAIL ===
SMTP_PROVIDER=brevo
SMTP_API_KEY=
SMTP_FROM_NAME=Kleinkunst Dashboard
SMTP_FROM_EMAIL=noreply@example.org

# === KI ===
OPENAI_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434

# === FEATURE FLAGS ===
FEATURE_AI_ASSISTANT=true
FEATURE_SOCIAL_MEDIA=true
FEATURE_GEMA=true
FEATURE_ADVANCED_ANALYTICS=false
